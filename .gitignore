# Office temporary files
~$*
*.tmp

# Office workbooks are ignored until they pass the public-safety checklist.
*.xls
*.xlsx
*.xlsm
*.xlsb

# Checked sample workbooks may be tracked only in this reviewed location.
!samples/checked/
!samples/checked/README.md
!samples/checked/**/*.xls
!samples/checked/**/*.xlsx
!samples/checked/**/*.xlsm
!samples/checked/**/*.xlsb

# Local/generated workbooks that have not been public-safety checked.
samples/generated/
outputs/**/scratch/

# Local tool state
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs that may contain local paths
*.log

# Keep exported VBA reviewable before commit.
!src/**/*.bas
!src/**/*.cls
!samples/**/*.md
!samples/**/*.csv
