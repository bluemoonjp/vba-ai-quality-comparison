# Office temporary files
~$*
*.tmp

# Office workbooks are ignored until they pass the public-safety checklist.
*.xls
*.xlsx
*.xlsm
*.xlsb

# Checked sample workbooks may be tracked only in reviewed sample locations.
!experiments/**/samples/workbooks/
!experiments/**/samples/workbooks/**/*.xlsx

# Local/generated workbooks that have not been public-safety checked.
samples/generated/
outputs/**/scratch/
experiments/**/samples/generated/
experiments/**/model-artifacts/**/scratch/

# Local tool state
.DS_Store
Thumbs.db
.vscode/
.idea/
node_modules/

# Logs that may contain local paths
*.log

# Keep exported VBA and experiment source data reviewable before commit.
!experiments/**/*.bas
!experiments/**/*.cls
!experiments/**/*.md
!experiments/**/*.csv
!experiments/**/*.mjs
